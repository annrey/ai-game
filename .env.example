# ============================================
# AI 说书人委员会 — 环境变量配置
# ============================================

# --- OpenAI 风格 API ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- DeepSeek API (OpenAI 兼容) ---
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# --- Moonshot API (OpenAI 兼容) ---
# OPENAI_API_KEY=sk-your-moonshot-key
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=moonshot-v1-8k

# --- Ollama 本地 ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- 本地 AI (llama.cpp / vLLM / LM Studio) ---
LOCAL_AI_ENDPOINT=http://localhost:1234/v1
LOCAL_AI_MODEL=local-model

# --- 默认 Provider ---
# 可选: openai | ollama | local
DEFAULT_PROVIDER=ollama

# --- 各代理独立模型配置（可选，覆盖默认） ---
# NARRATOR_PROVIDER=openai
# NARRATOR_MODEL=gpt-4o
# WORLD_KEEPER_PROVIDER=ollama
# WORLD_KEEPER_MODEL=llama3.2
# NPC_DIRECTOR_PROVIDER=ollama
# NPC_DIRECTOR_MODEL=llama3.2
# RULE_ARBITER_PROVIDER=local
# RULE_ARBITER_MODEL=local-model
# DRAMA_CURATOR_PROVIDER=ollama
# DRAMA_CURATOR_MODEL=llama3.2

# --- 游戏配置 ---
GAME_LANGUAGE=zh-CN
LOG_LEVEL=info
