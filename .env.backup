# ============================================
# AI 说书人委员会 — 本地 AI 配置
# ============================================
# 支持后端：ollama | local (LM Studio / Jan / llama.cpp)
# 切换后端：修改 DEFAULT_PROVIDER 即可
# ============================================

# ============================================
# 1. 选择默认后端（必选其一）
# ============================================
# 选项 A: Ollama（命令行管理，推荐新手）
DEFAULT_PROVIDER=ollama

# 选项 B: Local AI（OpenAI 兼容 API，支持 LM Studio / Jan / llama.cpp）
# DEFAULT_PROVIDER=local

# ============================================
# 2. Ollama 配置（使用 Ollama 时生效）
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# ============================================
# 3. Local AI 配置（使用 Local 时生效）
# ============================================
# 根据你使用的工具，选择对应的端点：

# --- LM Studio（默认端口 1234）---
# LOCAL_AI_ENDPOINT=http://localhost:1234/v1
# LOCAL_AI_MODEL=loaded-model-name

# --- Jan（默认端口 1337）---
# LOCAL_AI_ENDPOINT=http://localhost:1337/v1
# LOCAL_AI_MODEL=qwen2.5-7b-instruct

# --- llama.cpp（默认端口 8080）---
# LOCAL_AI_ENDPOINT=http://localhost:8080/v1
# LOCAL_AI_MODEL=qwen2.5-7b

# 当前激活的配置（配合 DEFAULT_PROVIDER=local 使用）
LOCAL_AI_ENDPOINT=http://localhost:1234/v1
LOCAL_AI_MODEL=local-model

# ============================================
# 4. OpenAI API（可选，云端备用）
# ============================================
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ============================================
# 5. 各代理独立模型配置
# ============================================
# 可以为每个代理指定不同的后端和模型
# 格式：{ROLE}_PROVIDER=ollama|local
#       {ROLE}_MODEL=模型名称

# --- 方案 A：全部使用 Ollama ---
NARRATOR_PROVIDER=ollama
NARRATOR_MODEL=qwen2.5:14b

WORLD_KEEPER_PROVIDER=ollama
WORLD_KEEPER_MODEL=qwen2.5:7b

NPC_DIRECTOR_PROVIDER=ollama
NPC_DIRECTOR_MODEL=qwen2.5:7b

RULE_ARBITER_PROVIDER=ollama
RULE_ARBITER_MODEL=qwen2.5:7b

DRAMA_CURATOR_PROVIDER=ollama
DRAMA_CURATOR_MODEL=qwen2.5:7b

# --- 方案 B：混合后端示例 ---
# Narrator 用 llama.cpp 跑 14B（高质量叙事）
# NARRATOR_PROVIDER=local
# NARRATOR_MODEL=qwen2.5-14b

# 其他代理用 Ollama 跑 7B（快速响应）
# WORLD_KEEPER_PROVIDER=ollama
# WORLD_KEEPER_MODEL=qwen2.5:7b
# ...

# ============================================
# 6. 游戏配置
# ============================================
GAME_LANGUAGE=zh-CN
LOG_LEVEL=info
